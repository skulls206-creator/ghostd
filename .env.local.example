# ─────────────────────────────────────────────────────────────
# GHOSTD — Local Development Environment
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# The full origin of the GHOSTD API server (Express backend running on Replit).
# This is the same URL the production site uses.
# Example: https://some-deployment-abcdef.spock.replit.dev
# Trailing slash is NOT needed — the app adds /api/* paths automatically.
VITE_API_BASE_URL=https://your-replit-backend-url-here.replit.dev

# Vite base path. Leave as "/" for local dev.
# Only change if deploying to a subpath (e.g., /ghostd/ for GitHub Pages).
VITE_BASE=/

# ─────────────────────────────────────────────────────────────
# CRP Exchange credentials (for the login page)
# Your Utopia Public Key and its password.
# These are the same credentials you use on crp.is.
# ─────────────────────────────────────────────────────────────
# CRP_PUBLIC_KEY=your-public-key-hex
# CRP_PASSWORD=your-password

# ─────────────────────────────────────────────────────────────
# Session secret (for the backend if you're also running it locally)
# Must be a random 32-byte hex string.
# ─────────────────────────────────────────────────────────────
# SESSION_SECRET=0123456789abcdef0123456789abcdef

# ─────────────────────────────────────────────────────────────
# Local PostgreSQL connection (for the backend if running locally)
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghostd
